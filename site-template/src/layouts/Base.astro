---
// Base layout — wraps every page with header, nav, and footer.
// To customize: edit the site name, navigation links, and footer text.
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Welcome to our website' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <!-- Site Header — edit navigation links above -->
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">MyBusiness</a>
      <nav>
        <ul class="site-nav">
          {navLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main>
    <slot />
  </main>

  <!-- Site Footer — edit company info below -->
  <footer class="site-footer">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} MyBusiness. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>
