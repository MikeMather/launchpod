---
// About Page — company info and team section
// To customize: edit the text content and team members below.
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const team = (await getCollection('team')).sort((a, b) => a.data.sort_order - b.data.sort_order);
---

<Base title="About | MyBusiness" description="Learn more about our company and team.">
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <h1 class="mb-8">About Us</h1>

      <!-- Company Story — edit this section to tell your story -->
      <div class="prose mb-8">
        <p>We are a passionate team dedicated to helping businesses succeed online. With years of experience in web development, design, and digital strategy, we deliver solutions that make a real difference.</p>
        <p>Our mission is simple: make the web work for you. Whether you need a new website, better search rankings, or a complete digital transformation, we have the skills and experience to make it happen.</p>
      </div>

      <!-- Team Section — pulled from src/content/team/ -->
      <h2 class="mb-8">Our Team</h2>
      <div class="grid grid-2">
        {team.map(member => (
          <div class="card">
            <h3>{member.data.name}</h3>
            <p class="text-light" style="font-size: var(--text-sm); margin-bottom: var(--space-2);">{member.data.role}</p>
            <p>{member.data.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
